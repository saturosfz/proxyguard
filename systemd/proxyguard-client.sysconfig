# Listen for UDP packets from WireGuard
# OPTIONAL, DEFAULT = 127.0.0.1:51820
#LISTEN=127.0.0.1:51820
#LISTEN=[::1]:51820

# TCP WebSocket Server URL
# REQUIRED
TO=wss://vpn.example.org/proxyguard/
#TO=wss://vpn.example.org/proxyguard/node.vpn.example.org/

# Mark WireGuard packets for matching in routing tables
# OPTIONAL, DEFAULT = 54321
#FWMARK=54321
